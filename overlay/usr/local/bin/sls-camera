#!/usr/bin/env bash
# Firmware-installed launcher for SLS Camera (appliance / tablet)
#
# Respects the *app's* quit intent via process exit codes (sls-camera#4):
#   0  — clean quit (return to session / desktop)
#   10 — operator requested host power-off
#   11 — relaunch app (kiosk)
#
# Until the app emits those codes, set SLS_ON_QUIT=shutdown for legacy
# “any exit → poweroff” behavior, or SLS_QUIT_FALLBACK=shutdown with
# SLS_ON_QUIT=app (default) so exit 0 still powers off on current builds.
set -euo pipefail
export PATH="${HOME}/.local/bin:/usr/local/bin:${PATH}"

# Writable captures on appliance data volume when present
if [[ -d /data/sls-captures ]]; then
  export SLS_CAPTURES_DIR=/data/sls-captures
fi

APP_ROOT="${SLS_APP_ROOT:-/opt/sls-camera}"
VIEWER="${APP_ROOT}/software/linux/viewer"
if [[ ! -x "${VIEWER}/run.sh" ]]; then
  echo "SLS Camera not installed at ${VIEWER}" >&2
  exit 1
fi

# Exit-code contract (keep in sync with sls-camera issue #4 / viewer docs)
readonly SLS_EXIT_OK=0
readonly SLS_EXIT_POWEROFF=10
readonly SLS_EXIT_RELAUNCH=11

# How to interpret app exit:
#   app       — honor exit codes 10/11; exit 0 → SLS_QUIT_FALLBACK (default shutdown on appliance)
#   shutdown  — any exit → power off (legacy, ignore codes except we still run cleanup path)
#   restart   — any exit → relaunch
#   none      — any exit → return to desktop
SLS_ON_QUIT="${SLS_ON_QUIT:-app}"
# When SLS_ON_QUIT=app and exit code is 0 (today's app always does this on Quit):
SLS_QUIT_FALLBACK="${SLS_QUIT_FALLBACK:-shutdown}"

_power_off() {
  if command -v loginctl >/dev/null 2>&1; then
    loginctl poweroff 2>/dev/null && return 0
  fi
  if command -v systemctl >/dev/null 2>&1; then
    systemctl poweroff 2>/dev/null && return 0
  fi
  if command -v sudo >/dev/null 2>&1; then
    sudo -n /sbin/poweroff 2>/dev/null || sudo -n /usr/sbin/poweroff 2>/dev/null || true
  fi
  /sbin/poweroff 2>/dev/null || /usr/sbin/poweroff 2>/dev/null || true
}

_relaunch() {
  echo "SLS Camera: relaunching…"
  sleep 1
  exec /usr/local/bin/sls-camera "$@"
}

cd "${VIEWER}"
set +e
./run.sh "$@"
code=$?
set -e

echo "SLS Camera exited with code ${code} (SLS_ON_QUIT=${SLS_ON_QUIT})"

case "${SLS_ON_QUIT}" in
  app|respect|codes)
    case "${code}" in
      "${SLS_EXIT_POWEROFF}")
        echo "App requested power-off (exit ${SLS_EXIT_POWEROFF})"
        _power_off
        ;;
      "${SLS_EXIT_RELAUNCH}")
        echo "App requested relaunch (exit ${SLS_EXIT_RELAUNCH})"
        _relaunch "$@"
        ;;
      "${SLS_EXIT_OK}")
        # App clean quit — honor fallback until viewer implements #4 fully
        case "${SLS_QUIT_FALLBACK}" in
          shutdown|poweroff|off)
            echo "Clean quit (0); SLS_QUIT_FALLBACK=${SLS_QUIT_FALLBACK} → power off"
            _power_off
            ;;
          restart|loop|relaunch)
            _relaunch "$@"
            ;;
          none|exit|desktop|"")
            exit 0
            ;;
          *)
            echo "Unknown SLS_QUIT_FALLBACK=${SLS_QUIT_FALLBACK}" >&2
            exit 0
            ;;
        esac
        ;;
      *)
        # Crash / error: do not power off; optional relaunch
        if [[ "${SLS_QUIT_ON_ERROR:-none}" == "restart" ]]; then
          _relaunch "$@"
        fi
        exit "${code}"
        ;;
    esac
    exit "${code}"
    ;;
  shutdown|poweroff|off)
    echo "Legacy SLS_ON_QUIT=shutdown → power off"
    _power_off
    exit "${code}"
    ;;
  restart|loop|relaunch)
    _relaunch "$@"
    ;;
  none|exit|desktop)
    exit "${code}"
    ;;
  *)
    echo "Unknown SLS_ON_QUIT=${SLS_ON_QUIT}; exiting" >&2
    exit "${code}"
    ;;
esac
