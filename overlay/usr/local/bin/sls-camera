#!/usr/bin/env bash
# Firmware-installed launcher for SLS Camera (appliance / tablet)
#
# App exit-code contract (sls-camera#4):
#   0  — clean quit
#   10 — operator requested host power-off
#   11 — relaunch app (kiosk)
#
# Defaults (appliance, post sls-camera#4):
#   SLS_QUIT_ACTION=shutdown  — app shows "Power off?" and exits 10
#   SLS_ON_QUIT=app           — honor exit codes
#   SLS_QUIT_FALLBACK=none    — exit 0 does NOT power off (app must send 10)
set -u
export PATH="${HOME}/.local/bin:/usr/local/bin:${PATH}"

LOG="${SLS_LAUNCHER_LOG:-/data/sls-captures/launcher.log}"
if [[ ! -d "$(dirname "$LOG")" ]]; then
  LOG="${TMPDIR:-/tmp}/sls-camera-launcher.log"
fi
_log() {
  local line="[$(date -Iseconds 2>/dev/null || date)] $*"
  echo "$line" >>"$LOG" 2>/dev/null || true
  echo "$line"
}

# Writable captures on appliance data volume when present
if [[ -d /data/sls-captures ]]; then
  export SLS_CAPTURES_DIR=/data/sls-captures
fi

# Force appliance quit mode in the app (Settings "Power off on Quit" ON for process)
export SLS_QUIT_ACTION="${SLS_QUIT_ACTION:-shutdown}"

APP_ROOT="${SLS_APP_ROOT:-/opt/sls-camera}"
VIEWER="${APP_ROOT}/software/linux/viewer"
# FAT32 field-USB installs often drop +x; repair before launch
if [[ -f "${VIEWER}/run.sh" && ! -x "${VIEWER}/run.sh" ]]; then
  chmod +x "${VIEWER}/run.sh" 2>/dev/null || true
fi
if [[ ! -f "${VIEWER}/run.sh" ]]; then
  _log "ERROR: SLS Camera not installed at ${VIEWER}"
  exit 1
fi
if [[ ! -x "${VIEWER}/run.sh" ]]; then
  _log "WARN: run.sh not executable — launching via bash"
fi

readonly SLS_EXIT_OK=0
readonly SLS_EXIT_POWEROFF=10
readonly SLS_EXIT_RELAUNCH=11

SLS_ON_QUIT="${SLS_ON_QUIT:-app}"
SLS_QUIT_FALLBACK="${SLS_QUIT_FALLBACK:-none}"

_power_off() {
  _log "power-off requested (uid=$(id -u) user=$(id -un))"
  # Prefer passwordless sudo paths that match /etc/sudoers.d/sls-poweroff.
  # Do NOT treat bare loginctl/systemctl as success — they often fail without polkit.
  if command -v sudo >/dev/null 2>&1; then
    if sudo -n /usr/sbin/poweroff >>"$LOG" 2>&1; then
      _log "poweroff via sudo /usr/sbin/poweroff"
      return 0
    fi
    if sudo -n /sbin/poweroff >>"$LOG" 2>&1; then
      _log "poweroff via sudo /sbin/poweroff"
      return 0
    fi
    if sudo -n /usr/bin/systemctl poweroff >>"$LOG" 2>&1; then
      _log "poweroff via sudo systemctl poweroff"
      return 0
    fi
    if sudo -n /bin/systemctl poweroff >>"$LOG" 2>&1; then
      _log "poweroff via sudo /bin/systemctl poweroff"
      return 0
    fi
  fi
  # Last resorts (may work as root only)
  /usr/sbin/poweroff >>"$LOG" 2>&1 || /sbin/poweroff >>"$LOG" 2>&1 || true
  _log "ERROR: all poweroff methods failed — see log and sudoers.d/sls-poweroff"
  return 1
}

_relaunch() {
  _log "relaunching app…"
  sleep 1
  exec /usr/local/bin/sls-camera "$@"
}

# Wait for X (blank-screen races: autostart before compositor/DSI ready)
export DISPLAY="${DISPLAY:-:0}"
if [[ -z "${WAYLAND_DISPLAY:-}" ]]; then
  for _ in $(seq 1 40); do
    if command -v xset >/dev/null 2>&1 && xset q >/dev/null 2>&1; then
      break
    fi
    if command -v xrandr >/dev/null 2>&1 && xrandr >/dev/null 2>&1; then
      break
    fi
    sleep 0.5
  done
fi

# Fleet policy: lock landscape before app (native glass may be portrait — see sls-lock-landscape)
if [[ -n "${DISPLAY:-}" ]] && [[ -x /usr/local/bin/sls-lock-landscape ]]; then
  /usr/local/bin/sls-lock-landscape || true
  sleep 0.5
  /usr/local/bin/sls-lock-landscape || true
elif [[ -n "${DISPLAY:-}" ]] && command -v sls-lock-landscape >/dev/null 2>&1; then
  sls-lock-landscape || true
fi

# Best-effort display geometry for field/tablet notes (app team may log more precisely)
if [[ -n "${DISPLAY:-}" ]] && command -v xrandr >/dev/null 2>&1; then
  _geom="$(xrandr 2>/dev/null | awk '/ connected/{print; exit}')"
  _log "display: ${_geom:-unknown} (landscape lock; see sls-camera#6 for Settings fit)"
fi

# Keep panel awake while field app runs (also see sls-disable-dpms autostart)
if [[ -n "${DISPLAY:-}" ]] && command -v xset >/dev/null 2>&1; then
  xset s off 2>/dev/null || true
  xset s noblank 2>/dev/null || true
  xset -dpms 2>/dev/null || true
fi

cd "${VIEWER}"
_log "starting run.sh args=$* SLS_ON_QUIT=${SLS_ON_QUIT} FALLBACK=${SLS_QUIT_FALLBACK} SLS_QUIT_ACTION=${SLS_QUIT_ACTION:-}"
set +e
if [[ -x ./run.sh ]]; then
  ./run.sh "$@"
else
  bash ./run.sh "$@"
fi
code=$?
set +e

_log "app exited code=${code}"

case "${SLS_ON_QUIT}" in
  app|respect|codes)
    case "${code}" in
      "${SLS_EXIT_POWEROFF}")
        _log "exit ${SLS_EXIT_POWEROFF}: app requested power-off"
        _power_off || true
        ;;
      "${SLS_EXIT_RELAUNCH}")
        _log "exit ${SLS_EXIT_RELAUNCH}: app requested relaunch"
        _relaunch "$@"
        ;;
      "${SLS_EXIT_OK}")
        case "${SLS_QUIT_FALLBACK}" in
          shutdown|poweroff|off)
            _log "exit 0 + FALLBACK=shutdown → power off"
            _power_off || true
            ;;
          restart|loop|relaunch)
            _relaunch "$@"
            ;;
          none|exit|desktop|"")
            _log "exit 0 + FALLBACK=none → desktop"
            ;;
          *)
            _log "unknown SLS_QUIT_FALLBACK=${SLS_QUIT_FALLBACK}"
            ;;
        esac
        ;;
      *)
        _log "non-zero exit ${code} (crash?) — not powering off"
        if [[ "${SLS_QUIT_ON_ERROR:-none}" == "restart" ]]; then
          _relaunch "$@"
        fi
        ;;
    esac
    exit "${code}"
    ;;
  shutdown|poweroff|off)
    _log "SLS_ON_QUIT=shutdown → power off (any exit)"
    _power_off || true
    exit "${code}"
    ;;
  restart|loop|relaunch)
    _relaunch "$@"
    ;;
  none|exit|desktop)
    _log "SLS_ON_QUIT=none → desktop"
    exit "${code}"
    ;;
  *)
    _log "unknown SLS_ON_QUIT=${SLS_ON_QUIT}"
    exit "${code}"
    ;;
esac
