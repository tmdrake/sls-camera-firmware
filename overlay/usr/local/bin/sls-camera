#!/usr/bin/env bash
# Firmware-installed launcher for SLS Camera (appliance / tablet)
set -euo pipefail
export PATH="${HOME}/.local/bin:/usr/local/bin:${PATH}"

# Writable captures on appliance data volume when present
if [[ -d /data/sls-captures ]]; then
  export SLS_CAPTURES_DIR=/data/sls-captures
fi

APP_ROOT="${SLS_APP_ROOT:-/opt/sls-camera}"
VIEWER="${APP_ROOT}/software/linux/viewer"
if [[ ! -x "${VIEWER}/run.sh" ]]; then
  echo "SLS Camera not installed at ${VIEWER}" >&2
  exit 1
fi

# After the operator quits the app (Quit / Q / window close):
#   shutdown  — power off the machine (default on appliance images)
#   restart   — launch the app again (kiosk loop; useful if crash-prone)
#   none      — exit the launcher only (desktop stays up)
SLS_ON_QUIT="${SLS_ON_QUIT:-shutdown}"

cd "${VIEWER}"
set +e
./run.sh "$@"
code=$?
set -e

_power_off() {
  # Prefer user session poweroff; fall back to systemctl / sudo (see sudoers drop-in)
  if command -v loginctl >/dev/null 2>&1; then
    loginctl poweroff 2>/dev/null && return 0
  fi
  if command -v systemctl >/dev/null 2>&1; then
    systemctl poweroff 2>/dev/null && return 0
  fi
  if command -v sudo >/dev/null 2>&1; then
    sudo -n /sbin/poweroff 2>/dev/null || sudo -n /usr/sbin/poweroff 2>/dev/null || true
  fi
  /sbin/poweroff 2>/dev/null || /usr/sbin/poweroff 2>/dev/null || true
}

case "${SLS_ON_QUIT}" in
  shutdown|poweroff|off)
    echo "SLS Camera exited (code ${code}); powering off (SLS_ON_QUIT=${SLS_ON_QUIT})…"
    _power_off
    exit "${code}"
    ;;
  restart|loop|relaunch)
    echo "SLS Camera exited (code ${code}); relaunching…"
    sleep 1
    exec /usr/local/bin/sls-camera "$@"
    ;;
  none|exit|desktop)
    exit "${code}"
    ;;
  *)
    echo "Unknown SLS_ON_QUIT=${SLS_ON_QUIT}; exiting without poweroff" >&2
    exit "${code}"
    ;;
esac
