#!/usr/bin/env bash
# If the tablet appears to be charging for IDLE_MINUTES, power off.
# Use case: RCA dedicated charger wakes unit on plug; Kinect cannot run on that
# charge path — shut down after a short window so battery can fill unattended.
#
# Config: /etc/sls/charge-idle.conf
# Log:   /data/sls-captures/charge-idle.log (or /var/log if no /data)
set -u

CONF=/etc/sls/charge-idle.conf
ENABLED=1
IDLE_MINUTES=15
POLL_SEC=30
CAPACITY_TREND=1

if [[ -f "$CONF" ]]; then
  # shellcheck disable=SC1090
  source "$CONF" || true
fi

# Env override (install/lab)
[[ -n "${SLS_CHARGE_IDLE_ENABLED:-}" ]] && ENABLED="${SLS_CHARGE_IDLE_ENABLED}"
[[ -n "${SLS_CHARGE_IDLE_MINUTES:-}" ]] && IDLE_MINUTES="${SLS_CHARGE_IDLE_MINUTES}"

LOG=/data/sls-captures/charge-idle.log
if [[ ! -d "$(dirname "$LOG")" ]]; then
  LOG=/var/log/sls-charge-idle.log
fi
_log() {
  local line="[$(date -Iseconds 2>/dev/null || date)] $*"
  echo "$line" >>"$LOG" 2>/dev/null || true
}

if [[ "${ENABLED}" != "1" && "${ENABLED}" != "true" && "${ENABLED}" != "yes" ]]; then
  _log "disabled (ENABLED=${ENABLED}) — exiting"
  exit 0
fi

NEED=$((IDLE_MINUTES * 60))
if [[ "$NEED" -lt 60 ]]; then
  NEED=60
fi
_log "start IDLE_MINUTES=${IDLE_MINUTES} POLL_SEC=${POLL_SEC} need=${NEED}s"

_read() {
  local f="$1"
  [[ -r "$f" ]] || return 1
  tr -d ' \n' <"$f" 2>/dev/null
}

# Returns 0 if we believe AC/charge path is active
_is_charging() {
  local ps type status online cur cap
  for ps in /sys/class/power_supply/*; do
    [[ -d "$ps" ]] || continue
    type="$(_read "$ps/type" || true)"
    case "$type" in
      Mains|USB|Wireless)
        online="$(_read "$ps/online" || echo 0)"
        if [[ "$online" == "1" ]]; then
          echo "supply=$(basename "$ps") online=1"
          return 0
        fi
        ;;
      Battery)
        status="$(_read "$ps/status" || true)"
        case "$status" in
          Charging|Full|"Not charging")
            # "Not charging" often means full / on AC with charge paused
            echo "battery status=$status"
            return 0
            ;;
        esac
        # Some PMICs report positive current_now while charging (µA)
        cur="$(_read "$ps/current_now" || echo 0)"
        if [[ "$cur" =~ ^-?[0-9]+$ ]] && [[ "$cur" -gt 50000 ]]; then
          echo "battery current_now=${cur}uA"
          return 0
        fi
        ;;
    esac
  done
  return 1
}

_cap() {
  local ps c
  for ps in /sys/class/power_supply/*; do
    [[ -r "$ps/capacity" ]] || continue
    type="$(_read "$ps/type" || true)"
    [[ "$type" == "Battery" ]] || continue
    c="$(_read "$ps/capacity" || true)"
    [[ "$c" =~ ^[0-9]+$ ]] && echo "$c" && return 0
  done
  echo ""
}

accum=0
prev_cap=""
trend_hits=0

while true; do
  reason=""
  if reason=$(_is_charging); then
    accum=$((accum + POLL_SEC))
    _log "charging_hint (${reason}) accum=${accum}s/${NEED}s cap=$(_cap)"
  elif [[ "${CAPACITY_TREND}" == "1" ]]; then
    cap="$(_cap)"
    if [[ -n "$cap" && -n "$prev_cap" && "$cap" -gt "$prev_cap" ]]; then
      trend_hits=$((trend_hits + 1))
      accum=$((accum + POLL_SEC))
      _log "capacity_trend ${prev_cap}->${cap} hits=${trend_hits} accum=${accum}s/${NEED}s"
    else
      # Not clearly charging — decay timer slowly so brief glitches don't stick forever
      if [[ "$accum" -gt 0 ]]; then
        accum=$((accum - POLL_SEC))
        [[ "$accum" -lt 0 ]] && accum=0
        _log "not_charging decay accum=${accum}s cap=${cap:-?} status_hint"
      fi
      trend_hits=0
    fi
    prev_cap="${cap:-$prev_cap}"
  else
    if [[ "$accum" -gt 0 ]]; then
      accum=$((accum - POLL_SEC))
      [[ "$accum" -lt 0 ]] && accum=0
    fi
    _log "not_charging accum=${accum}s"
  fi

  # Always update prev_cap for trend
  cnow="$(_cap)"
  [[ -n "$cnow" ]] && prev_cap="$cnow"

  if [[ "$accum" -ge "$NEED" ]]; then
    _log "IDLE charge window met — powering off (Kinect unusable on dedicated charge path / unattended charge)"
    # Prefer passwordless sudo like appliance launcher
    if command -v sudo >/dev/null 2>&1; then
      sudo -n /usr/sbin/poweroff >>"$LOG" 2>&1 \
        || sudo -n /sbin/poweroff >>"$LOG" 2>&1 \
        || /usr/sbin/poweroff >>"$LOG" 2>&1 \
        || true
    else
      /usr/sbin/poweroff >>"$LOG" 2>&1 || true
    fi
    exit 0
  fi

  sleep "${POLL_SEC}"
done
