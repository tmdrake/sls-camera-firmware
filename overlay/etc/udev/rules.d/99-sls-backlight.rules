# Allow appliance user (group video) to set panel brightness.
# Without this, /sys/class/backlight/*/brightness is root-only and
# SLS Settings ± greys out or cannot change the RCA/Cherry Trail panel.
#
# user `sls` is added to group video in install-appliance.sh.
ACTION=="add", SUBSYSTEM=="backlight", TEST=="brightness", RUN+="/bin/chgrp video /sys/class/backlight/%k/brightness"
ACTION=="add", SUBSYSTEM=="backlight", TEST=="brightness", RUN+="/bin/chmod g+w /sys/class/backlight/%k/brightness"
ACTION=="add", SUBSYSTEM=="backlight", TEST=="bl_power", RUN+="/bin/chgrp video /sys/class/backlight/%k/bl_power"
ACTION=="add", SUBSYSTEM=="backlight", TEST=="bl_power", RUN+="/bin/chmod g+w /sys/class/backlight/%k/bl_power"
