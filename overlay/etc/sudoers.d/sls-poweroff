# Allow appliance user to power off without a password (Quit → shutdown path).
# Installed by install-appliance.sh (mode 0440).
Defaults!/usr/sbin/poweroff !requiretty
Defaults!/sbin/poweroff !requiretty
Defaults!/usr/bin/systemctl !requiretty
sls ALL=(root) NOPASSWD: /usr/sbin/poweroff, /sbin/poweroff, /usr/sbin/shutdown, /sbin/shutdown, /usr/bin/systemctl poweroff, /bin/systemctl poweroff
